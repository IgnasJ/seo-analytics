GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
ENCRYPTION_KEY=
CRUX_API_KEY=
# PageSpeed Insights API key — same Google Cloud project as CRUX_API_KEY is
# fine; both APIs share quota when restricted to the same key.
PSI_API_KEY=
DB_PATH=./data/analytics.db
# App auth — required for any deployment beyond localhost. If APP_PASSWORD is
# unset the app runs without auth (convenient for local dev). The cookie is
# signed with ENCRYPTION_KEY, so make sure that's set if APP_PASSWORD is.
APP_USERNAME=admin
APP_PASSWORD=
